# Frontend env (Vite reads VITE_* at build time).
# Copy to .env and fill in values.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Override Vite's /api proxy target. Defaults to http://127.0.0.1:8000.
# VITE_BACKEND_URL=http://127.0.0.1:8000

# Dev only — bypass Supabase auth and use a mock user. Set the backend's
# AUTH_MOCK=true to mirror this so the Penny endpoints accept requests too.
# VITE_AUTH_MOCK=true

# Google Meet link shown on consultation cards. Leave empty to hide the
# join link/QR (e.g. when consultations aren't offered on this deployment).
# VITE_MEET_LINK=https://meet.google.com/xxx-xxxx-xxx

# Currency conversion API used during onboarding. Defaults to the free
# exchangerate-api INR endpoint when unset.
# VITE_FX_API_URL=https://api.exchangerate-api.com/v4/latest/INR
