# Frontend env (Vite reads VITE_* at build time).
# Copy to .env and fill in values.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Override Vite's /api proxy target. Defaults to http://127.0.0.1:8000.
# VITE_BACKEND_URL=http://127.0.0.1:8000

# Dev only — bypass Supabase auth and use a mock user. Set the backend's
# AUTH_MOCK=true to mirror this so /api/penny accepts requests too.
# VITE_AUTH_MOCK=true
