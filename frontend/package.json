{
  "name": "finpath-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "dev:backend": "node scripts/run-backend.mjs",
    "dev:all": "concurrently -n backend,frontend -c yellow,cyan \"pnpm dev:backend\" \"pnpm dev\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "fixtures": "tsx scripts/dump-fixtures.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:strict": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "cd .. && git config core.hooksPath .husky || true"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.104.0",
    "canvas-confetti": "1.9.4",
    "html-to-image": "^1.11.13",
    "lucide-react": "0.487.0",
    "motion": "12.23.24",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.6.205",
    "qrcode.react": "^4.2.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-router": "7.13.0",
    "recharts": "2.15.2",
    "tesseract.js": "^7.0.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "4.1.12",
    "@types/canvas-confetti": "^1.9.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "@vitejs/plugin-react": "4.7.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^15.15.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "tailwindcss": "4.1.12",
    "tsx": "^4.21.1",
    "typescript": "~5.6.3",
    "typescript-eslint": "^8.59.3",
    "vite": "6.3.5",
    "vitest": "^4.1.6"
  },
  "pnpm": {
    "overrides": {
      "vite": "6.3.5"
    }
  }
}