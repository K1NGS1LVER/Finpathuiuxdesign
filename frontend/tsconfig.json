{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true
    /* TODO(strict): re-enable noUncheckedIndexedAccess + exactOptionalPropertyTypes
       once the 125 pre-existing violations are addressed in store/onboarding-hook
       decomposition phases. Tracked in plans/onboarding-loading-screen-needs-merry-wozniak.md */
  },
  "include": ["src"]
}
