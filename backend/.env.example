GROQ_API_KEY=
HOST=127.0.0.1
PORT=8000
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Supabase auth (Phase 1)
# Project JWT secret (Settings → API → JWT Settings → "JWT Secret"). HS256.
SUPABASE_URL=
SUPABASE_JWT_SECRET=
SUPABASE_JWT_AUD=authenticated
SUPABASE_JWT_ALGORITHM=HS256

# Supabase REST (Phase 3 — chat_history + proposals writes via PostgREST)
# Anon key needed to call PostgREST under the user's JWT (RLS enforced).
# Service-role key only used by the proposal-expiry background job.
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Dev only — bypass JWT verification on /api/penny entirely.
# Mirror the frontend VITE_AUTH_MOCK toggle when set to true.
# Leave commented (or set false) for any real run.
# AUTH_MOCK=true
